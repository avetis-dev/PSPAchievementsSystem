runtime_prx/
converter/
tools/
external/
docs/

# Build artifacts
*.o
*.elf
*.prx
*.PBP
*.sfo
*.exp

# Build directories
build/
out/

# Python cache
__pycache__/
*.pyc
*.pyo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
*.bak
